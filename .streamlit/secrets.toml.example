# Copy to .streamlit/secrets.toml (gitignored) to override defaults.
# Controls how the Streamlit UI sources predictions.
#
# INFERENCE_MODE:
#   "local" (default) — runs the joblib models in-process. Zero network, always works.
#   "api"             — POSTs to the deployed FastAPI, with automatic fallback to local
#                       if the API is cold/unreachable.
INFERENCE_MODE = "local"

# Only used when INFERENCE_MODE = "api": base URL of the deployed FastAPI service.
API_URL = "https://sommelier-api.onrender.com"
